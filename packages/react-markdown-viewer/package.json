{
	"name": "@typefm/react-markdown-viewer",
	"version": "0.2.0",
	"description": "High-performance React component for rendering markdown with streaming support, optimized for LLM chat interfaces",
	"license": "MIT",
	"sideEffects": false,
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./utils": {
			"types": "./dist/utils.d.ts",
			"import": "./dist/utils.js"
		},
		"./styles.css": "./dist/styles/index.css"
	},
	"files": [
		"dist/",
		"README.md",
		"LICENSE"
	],
	"scripts": {
		"dev": "vite",
		"build": "tsc && cp -r src/styles dist/",
		"prepack": "npm run build",
		"lint": "tsc --noEmit",
		"test": "vitest run"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/jveres/typefm",
		"directory": "packages/react-markdown-viewer"
	},
	"keywords": [
		"markdown",
		"react",
		"streaming",
		"llm",
		"chat",
		"viewer",
		"github",
		"gfm",
		"commonmark",
		"wasm",
		"syntax-highlighting",
		"katex",
		"math"
	],
	"publishConfig": {
		"access": "public"
	},
	"dependencies": {
		"@typefm/comrak-wasm": "^0.2.0",
		"highlight.js": "^11.11.1",
		"idiomorph": "^0.7.4",
		"katex": "^0.16.28"
	},
	"peerDependencies": {
		"react": "^19.0.0",
		"react-dom": "^19.0.0"
	},
	"devDependencies": {
		"@testing-library/react": "^16.3.2",
		"@types/react": "^19.2.11",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^5.1.3",
		"jsdom": "^28.0.0",
		"lightgallery": "^2.9.0",
		"mermaid": "^11.14.0",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"typescript": "^5.9.3",
		"vite": "^7.3.1",
		"vitest": "^4.0.18"
	}
}
