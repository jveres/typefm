{
	"name": "@typefm/react-markdown-viewer",
	"version": "0.0.1",
	"private": true,
	"sideEffects": false,
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./utils": {
			"types": "./dist/utils.d.ts",
			"import": "./dist/utils.js"
		},
		"./styles.css": "./dist/styles/index.css"
	},
	"scripts": {
		"dev": "vite",
		"build": "tsc && cp -r src/styles dist/",
		"lint": "tsc --noEmit",
		"test": "vitest run"
	},
	"dependencies": {
		"@typefm/comrak-wasm": "workspace:*",
		"highlight.js": "^11.11.1",
		"idiomorph": "^0.7.4",
		"katex": "^0.16.28"
	},
	"peerDependencies": {
		"react": "^19.0.0",
		"react-dom": "^19.0.0"
	},
	"devDependencies": {
		"@testing-library/react": "^16.3.2",
		"@types/react": "^19.2.11",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^5.1.3",
		"jsdom": "^28.0.0",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"typescript": "^5.9.3",
		"vite": "^7.3.1",
		"vitest": "^4.0.18"
	}
}
